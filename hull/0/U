FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (-7.46 0 0);

boundaryField
{
    inlet
    {
        type            uniformFixedValue;
        uniformValue    
        {
            type            constant;
            value           (-7.46 0 0);
        }
        value           uniform (-7.46 0 0);
    }
    outlet
    {
        type            zeroGradient;
    }
    top
    {
        type            symmetryPlane;
    }
    bottom
    {
        type            symmetryPlane;
    }
    front
    {
        type            symmetryPlane;
    }
    back
    {
        type            symmetryPlane;
    }
    casco
    {
        type            noSlip;
    }
}
