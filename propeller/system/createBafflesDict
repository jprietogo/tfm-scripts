FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      createBafflesDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

internalFacesOnly  true;

baffles
{
    NCCInterface
    {
	type		faceZone;
	zoneName	NCCInterface;

	patches
    	{
	    owner
	    {
		name	rotatingZoneOuter;
		type 	wall;
	    }

	    neighbour
	    {
		name	rotatingZoneInner;
		type	wall;
	    }
        }
    }       
}

